# =============================================================================
# AI-Powered Genomics Platform - Environment Configuration
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=GenomicsAI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# DATABASE CONFIGURATION (Supabase PostgreSQL)
# =============================================================================
# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database Connection Pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# Database URLs (Supabase handles connection pooling)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# =============================================================================
# CACHING CONFIGURATION (Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=genomics-data
MINIO_SECURE=false
MINIO_REGION=us-east-1

# =============================================================================
# ML MODEL CONFIGURATION
# =============================================================================
# Model Storage
MODEL_STORAGE_PATH=/app/models
MODEL_CACHE_SIZE=10

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
USE_GPU=true
GPU_MEMORY_LIMIT=0.8

# Model Endpoints
VARIANT_PREDICTOR_URL=http://localhost:8001
DRUG_RESPONSE_MODEL_URL=http://localhost:8002
BIOMARKER_MODEL_URL=http://localhost:8003
NLP_MODEL_URL=http://localhost:8004

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================
# NCBI APIs
NCBI_API_KEY=your-ncbi-api-key
NCBI_EMAIL=your-email@domain.com

# EBI APIs
EBI_API_KEY=your-ebi-api-key

# DrugBank API
DRUGBANK_API_KEY=your-drugbank-api-key

# ChEMBL API
CHEMBL_API_KEY=your-chembl-api-key

# =============================================================================
# DATASET CONFIGURATION
# =============================================================================
# Dataset Storage Paths
TCGA_DATA_PATH=/data/tcga
GENOMES_1000_DATA_PATH=/data/1000genomes
ENCODE_DATA_PATH=/data/encode
GEO_DATA_PATH=/data/geo
CLINVAR_DATA_PATH=/data/clinvar
SRA_DATA_PATH=/data/sra
PUBMED_DATA_PATH=/data/pubmed
GNOMAD_DATA_PATH=/data/gnomad
DRUGBANK_DATA_PATH=/data/drugbank
CHEMBL_DATA_PATH=/data/chembl
CPTAC_DATA_PATH=/data/cptac

# Dataset Update Intervals (in hours)
DATASET_UPDATE_INTERVAL=24
DATASET_BACKUP_INTERVAL=168

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# =============================================================================
# MONITORING & METRICS
# =============================================================================
# Prometheus Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Health Check
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
MAX_FILE_SIZE=1073741824  # 1GB
ALLOWED_FILE_TYPES=.vcf,.bam,.fastq,.csv,.tsv,.json
UPLOAD_PATH=/app/uploads
TEMP_PATH=/app/temp

# =============================================================================
# CELERY CONFIGURATION (Background Tasks)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Development Server
DEV_SERVER_HOST=0.0.0.0
DEV_SERVER_PORT=8000
DEV_SERVER_RELOAD=true

# Frontend Development
FRONTEND_URL=http://localhost:3000
FRONTEND_API_URL=http://localhost:8000

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# Production Server
PROD_SERVER_HOST=0.0.0.0
PROD_SERVER_PORT=8000
PROD_SERVER_WORKERS=4

# SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pem

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/test_db
TEST_REDIS_URL=redis://localhost:6379/15
TEST_MINIO_BUCKET=test-genomics-data

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# Docker Configuration
DOCKER_IMAGE_TAG=genomics-ai:latest
DOCKER_REGISTRY=your-registry.com

# Kubernetes Configuration
K8S_NAMESPACE=genomics-ai
K8S_REPLICAS=3

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups 